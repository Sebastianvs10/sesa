# ============================================
# SESA - Sistema Electrónico de Salud
# Monorepo .gitignore (raíz)
# ============================================

# ── OS ──
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ── IDEs / Editors ──
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project
.c9/
*.launch

# ── Cursor AI ──
.cursor/

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ── Environment / Secrets ──
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.jks

# ── Uploads (runtime data) ──
uploads/
